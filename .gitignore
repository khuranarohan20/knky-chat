# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Build outputs ────────────────────────────────────────────────────────────
build/
dist/
out/
.output/

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
# Compiled output must never land in src/ (belongs in dist/). Guards against
# stray `tsc` runs that emit next to sources. src/ holds .ts/.tsx/.css only.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# ─── Env files ────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template

# ─── Test & Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Cache ────────────────────────────────────────────────────────────────────
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz

# ─── Editor ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── React Router (auto-generated types) ──────────────────────────────────────
.react-router/

# ─── Claude Code ──────────────────────────────────────────────────────────────
.claude/settings.local.json
