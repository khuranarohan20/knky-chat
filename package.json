{
  "name": "knky-chat",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @knky-chat/app dev",
    "build": "turbo run build",
    "build:packages": "pnpm --filter './packages/**' build",
    "build:app": "pnpm --filter @knky-chat/app build",
    "test": "turbo run test",
    "test:watch": "pnpm -r test:watch",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:packages && changeset publish"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@react-router/node": "^7.5.0",
    "@react-router/serve": "^7.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "converse.svc-client": "file:extra-modules/converse.svc-client-0.15.0.tgz",
    "date-fns": "^4.1.0",
    "idb-keyval": "^6.2.1",
    "isbot": "^5.1.17",
    "lodash": "^4.17.21",
    "lucide-react": "^0.488.0",
    "nanoid": "^5.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.5.0",
    "react-virtuoso": "^4.12.6",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "react-router-devtools": "^1.1.0",
    "tailwindcss": "^4.0.0",
    "turbo": "^2.9.9",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
